# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGO_URI=ENTER YOUR URL

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
PLAYER_JWT_SECRET=your_player_jwt_secret_here

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:8080

# Bravo/Brevo Email Configuration (required for approval + OTP + admin mail flows)
BRAVO_API_KEY=your_bravo_api_key

# Sender details shown in outbound mails
MAIL_SENDER_EMAIL=spkabaddigroupdhanbad@gmail.com
MAIL_SENDER_NAME=SP Kabaddi Group Dhanbad

# Optional: absolute logo URL used in branded email templates
CLUB_LOGO_URL=https://spkabaddi.me/Logo.png

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
